{
  "name": "codefluent",
  "displayName": "CodeFluent",
  "description": "Claude Code analytics dashboard — AI fluency scoring, usage tracking, and recommendations",
  "version": "0.1.0",
  "publisher": "frederick-douglas-pearce",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/frederick-douglas-pearce/codefluent"
  },
  "homepage": "https://github.com/frederick-douglas-pearce/codefluent#readme",
  "bugs": {
    "url": "https://github.com/frederick-douglas-pearce/codefluent/issues"
  },
  "keywords": [
    "claude",
    "ai",
    "fluency",
    "analytics",
    "anthropic"
  ],
  "galleryBanner": {
    "color": "#1A1A1A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codefluent.dashboard"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codefluent",
          "title": "CodeFluent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codefluent": [
        {
          "type": "webview",
          "id": "codefluent.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "codefluent.openPanel",
        "title": "CodeFluent: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "CodeFluent",
      "properties": {
        "codefluent.sessionDataPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom path to Claude Code session data directory. Leave empty to use the default (`~/.claude/projects/`).",
          "scope": "machine"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && mkdir -p shared && cp ../shared/benchmarks.json shared/ && cp -r ../shared/prompts shared/",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest --verbose"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.85.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0"
  }
}
