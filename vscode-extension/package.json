{
  "name": "codefluent",
  "displayName": "CodeFluent",
  "description": "Claude Code analytics dashboard — AI fluency scoring, usage tracking, and recommendations",
  "version": "0.1.0",
  "publisher": "codefluent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codefluent.openPanel",
        "title": "CodeFluent: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0"
  }
}
